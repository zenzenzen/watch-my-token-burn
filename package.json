{
  "name": "token-gauge",
  "version": "1.0.0",
  "description": "Superfast terminal dashboard for Claude Code token usage",
  "type": "module",
  "bin": {
    "token-gauge": "./src/main.js",
    "tg": "./src/main.js"
  },
  "scripts": {
    "start": "node src/main.js",
    "dev": "node --watch src/main.js",
